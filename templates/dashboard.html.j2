<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Platform SEO Audit Dashboard - {{ target.url }}</title>
  <style>
    /* Platform 橙白配色（对齐 memory 的 brand style）*/
    :root {
      --brand-orange: #FF6B00;
      --brand-orange-light: #FFE4D0;
      --bg-white: #FFFFFF;
      --text-dark: #1A1A1A;
      --text-secondary: #6B6B6B;
      --border-light: #E5E5E5;
      --color-blocker: #D32F2F;
      --color-high: #F57C00;
      --color-medium: #FBC02D;
      --color-low: #7CB342;
      --color-info: #039BE5;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      color: var(--text-dark);
      background: var(--bg-white);
      display: flex;
      min-height: 100vh;
    }

    /* 左侧固定导航 (per memory: HTML 报告必须有左侧 sidebar + 滚动高亮)*/
    aside.sidebar {
      width: 240px;
      position: fixed;
      top: 0;
      left: 0;
      height: 100vh;
      padding: 24px 16px;
      background: var(--brand-orange-light);
      border-right: 2px solid var(--brand-orange);
      overflow-y: auto;
    }
    aside.sidebar h2 {
      color: var(--brand-orange);
      font-size: 18px;
      margin-bottom: 16px;
    }
    aside.sidebar nav a {
      display: block;
      padding: 8px 12px;
      color: var(--text-dark);
      text-decoration: none;
      border-radius: 6px;
      margin-bottom: 4px;
      font-size: 14px;
    }
    aside.sidebar nav a:hover,
    aside.sidebar nav a.active {
      background: var(--brand-orange);
      color: white;
    }

    main {
      margin-left: 240px;
      padding: 32px 48px;
      max-width: 960px;
    }

    h1 { color: var(--brand-orange); margin-bottom: 8px; }
    h2 { margin: 32px 0 16px; color: var(--text-dark); }

    .verdict-card {
      padding: 24px;
      border-left: 6px solid var(--brand-orange);
      background: var(--brand-orange-light);
      border-radius: 8px;
      margin-bottom: 32px;
    }
    .score-display { font-size: 48px; font-weight: bold; color: var(--brand-orange); }

    .findings-summary { display: flex; gap: 16px; margin-bottom: 32px; }
    .severity-pill {
      padding: 12px 16px;
      border-radius: 8px;
      flex: 1;
      text-align: center;
    }
    .pill-blocker { background: var(--color-blocker); color: white; }
    .pill-high { background: var(--color-high); color: white; }
    .pill-medium { background: var(--color-medium); color: var(--text-dark); }
    .pill-low { background: var(--color-low); color: white; }
    .pill-info { background: var(--color-info); color: white; }

    .finding-card {
      padding: 20px;
      border: 1px solid var(--border-light);
      border-radius: 8px;
      margin-bottom: 16px;
    }
    .finding-card.blocker { border-left: 6px solid var(--color-blocker); }
    .finding-card.high { border-left: 6px solid var(--color-high); }
    .finding-card.medium { border-left: 6px solid var(--color-medium); }
    .finding-card.low { border-left: 6px solid var(--color-low); }

    code { background: var(--brand-orange-light); padding: 2px 6px; border-radius: 4px; }
    .meta { color: var(--text-secondary); font-size: 13px; }
  </style>
</head>
<body>
  <aside class="sidebar">
    <h2>SEO Audit</h2>
    <nav>
      <a href="#verdict" class="active">Final Verdict</a>
      <a href="#composite">Composite Scores</a>
      <a href="#summary">Summary</a>
      <a href="#blockers">Must Fix</a>
      <a href="#high">Should Fix</a>
      <a href="#medium">Nice to Fix</a>
      <a href="#info">Observations</a>
      <a href="#metrics">Metrics</a>
    </nav>
  </aside>

  <main>
    <h1>SEO Audit Report</h1>
    <p class="meta">Target: <code>{{ target.url }}</code> | Run: <code>{{ run_id }}</code></p>

    <section id="verdict" class="verdict-card">
      <h2>Final Verdict</h2>
      <p style="font-size: 32px; font-weight: bold;">{{ final_verdict.value }}</p>
      <p>Brand SEO Score</p>
      <div class="score-display">{{ '%.1f' % brand_seo_score }} / 100</div>
    </section>

    {% if composite_scores %}
    <section id="composite">
      <h2>📊 Composite Scores (页面级最佳组合)</h2>
      <table style="width:100%; border-collapse: collapse;">
        <thead style="background: var(--brand-orange-light);">
          <tr>
            <th style="padding: 12px; text-align: left;">维度</th>
            <th style="padding: 12px;">分数</th>
            <th style="padding: 12px; text-align: left;">最弱环节</th>
            <th style="padding: 12px;">明细</th>
          </tr>
        </thead>
        <tbody>
        {% for dim_name, dim_data in composite_scores.items() %}
        {% if dim_data and dim_data.get('composite_score') is not none %}
        <tr style="border-bottom: 1px solid var(--border-light);">
          <td style="padding: 12px; font-weight: 600;">{{ dim_name }}</td>
          <td style="padding: 12px; text-align: center;">
            {% set s = dim_data.get('composite_score') %}
            <span style="font-size: 18px; font-weight: bold; color: {% if s >= 0.8 %}var(--color-low){% elif s >= 0.6 %}var(--color-medium){% elif s >= 0.4 %}var(--color-high){% else %}var(--color-blocker){% endif %};">
              {{ '%.2f' % s }}
            </span>
          </td>
          <td style="padding: 12px;">
            <code>{{ dim_data.get('weakest_link', '—') }}</code>
          </td>
          <td style="padding: 12px; font-size: 12px;">
            {% if dim_data.get('breakdown') %}
              {% for k, v in dim_data.get('breakdown', {}).items() %}
                <span style="margin-right: 8px; opacity: {% if v.pass < 0.5 %}1{% else %}0.4{% endif %};">{{ k }}: {{ '%.1f' % v.pass }}</span>
              {% endfor %}
            {% endif %}
          </td>
        </tr>
        {% endif %}
        {% endfor %}
        </tbody>
      </table>
    </section>
    {% endif %}

    <section id="summary">
      <h2>Findings Summary</h2>
      <div class="findings-summary">
        {% for severity, findings in findings_by_severity.items() %}
        <div class="severity-pill pill-{{ severity.value }}">
          <strong>{{ severity.value | upper }}</strong>
          <p style="font-size: 24px;">{{ findings|length }}</p>
        </div>
        {% endfor %}
      </div>
    </section>

    {% for severity_name in ['blocker', 'high', 'medium', 'low', 'info'] %}
    <section id="{{ severity_name }}s">
      <h2>{{ severity_name | upper }} ({{ findings_by_severity.get(severity_name, []) | length }})</h2>
      {% for finding in findings_by_severity.get(severity_name, []) %}
      <div class="finding-card {{ severity_name }}">
        <strong>{{ finding.id }}</strong>
        <p class="meta">
          Platform: {{ finding.platform.value }} |
          Confidence: {{ '%.2f' % finding.confidence }} |
          Source: {{ finding.source.value }}
        </p>
        {% if finding.evidence.text_snippet %}
        <p style="margin-top: 12px;"><em>{{ finding.evidence.text_snippet }}</em></p>
        {% endif %}
        <p style="margin-top: 12px;"><strong>Fix:</strong> {{ finding.recommendation }}</p>
      </div>
      {% endfor %}
    </section>
    {% endfor %}

    <section id="metrics">
      <h2>Metrics</h2>
      <ul>
        <li>Duration: {{ total_metrics.duration_ms }} ms</li>
        <li>LLM Cost: ${{ '%.4f' % total_metrics.cost_usd }}</li>
        <li>Generated at: {{ generated_at }}</li>
      </ul>
    </section>
  </main>

  <script>
    // 滚动高亮 sidebar 当前 section
    const links = document.querySelectorAll('aside.sidebar nav a');
    const sections = document.querySelectorAll('main section');
    window.addEventListener('scroll', () => {
      let current = '';
      sections.forEach(s => {
        if (window.scrollY >= s.offsetTop - 100) current = s.id;
      });
      links.forEach(a => {
        a.classList.toggle('active', a.getAttribute('href') === '#' + current);
      });
    });
  </script>
</body>
</html>
